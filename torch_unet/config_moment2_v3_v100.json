{
  "_comment": "Second-moment (variance) model trained on top of the v3 EMA checkpoint. Variance network is a fresh UNet3dV2 with the same architecture as the mean model. Input: same arcsinh PCA-cleaned visibilities as v3. Target: (model_1(x) - y)^2 in arcsinh residual space, where model_1 is the frozen v3 EMA. Loss: logMSE.",

  "model_params": {
    "model_version": "v2",

    "filters": 24,
    "noiseamp": 1.5e-7,
    "n_fg": 11,

    "act": "smooth_leaky",
    "loss": "logmse",

    "pca_components_path": "/data101/makinen/hirax_sims/accelerator/train2_fixedpca_v2/pca_components_nfg11.pt",

    "levels": 3,
    "block": "preact_res",
    "n_blocks_per_stage": 2,
    "norm": "groupnorm",
    "norm_groups": 8,
    "activation": "silu",

    "pad_modes": ["circular", "reflect", "replicate"],

    "downsample_kind": "blurpool",
    "upsample_kind": "resize_conv",
    "strides": [[2, 2, 2], [2, 2, 2], [2, 2, 2]],

    "two_conv_head": true,

    "attention_gates": false,
    "use_se": false,

    "factored_convs": false,
    "film_conditioning": false,
    "film_cond_dim": 8,
    "freq_pos_encoding": false,
    "freq_pos_dim": 2
  },

  "moment2_params": {
    "model_name": "train2_v3_v100_moment2",
    "model_path": "/data101/makinen/hirax_sims/accelerator/",
    "mean_model_checkpoint": "/data101/makinen/hirax_sims/accelerator/train2_v3_v100/ema_state_dict.pt"
  },

  "training_params": {
    "learning_rate": 2.0e-4,

    "batch_size": 1,
    "grad_accum_steps": 2,

    "epochs": 80,
    "gradient_clip": 1.0,
    "early_stopping_patience": 20,
    "early_stopping_min_delta": 0.0001,
    "train_num_workers": 4,
    "val_num_workers": 2,
    "prefetch_factor": 2,

    "mixed_precision": "fp16",
    "use_compile": false,
    "compile_mode": "default",
    "use_grad_checkpoint": true,

    "seed": 42,
    "add_noise": true,
    "cosmopath": "/data101/makinen/hirax_sims/cosmo_gaussian_pb/",
    "galpath": "/data101/makinen/hirax_sims/more_baselines/galaxy_gaussian_pb/",
    "num_train": 128,

    "ra_shift_aug": true,

    "optimizer": "adamw",
    "weight_decay": 1.0e-4,

    "lr_schedule": "onecycle",
    "warmup_frac": 0.05,

    "ema_decay": 0.999
  }
}
